using CustomAttributeWithOrigin = (Mono.Cecil.CustomAttribute Attribute, Mono.Cecil.AssemblyDefinition Origin);

namespace Mono.Linker
{
    sealed class TypeMapNodeFactory(MarkStep _markStep, LinkContext _context)
    {

        internal MarkStep MarkStep => _markStep;
        internal LinkContext Context => _context;
        Dictionary<CustomAttribute, TypeMapAttributeKeptNode> _typeMapAttributeKeptNodes = new();
        internal TypeMapAttributeKeptNode GetTypeMapAttributeKeptNode(CustomAttribute attr)
        {
            ref var value = ref CollectionsMarshal.GetValueRefOrAddDefault(_typeMapAttributeKeptNodes, attr, out bool exists);
            if (!exists)
                value = new TypeMapAttributeKeptNode(attr);


        }

        internal RequiresExternalTrimTargetNode GetRequiresExternalTrimTargetNode(TypeMapAttributeKeptNode typeMapAttributeKeptNode, TypeReference trimTarget) => throw new NotImplementedException();
        internal DependencyNodeCore<TypeMapNodeFactory> GetExternalTrimTargetNode(TypeReference trimTarget) => throw new NotImplementedException();
        internal DependencyNodeCore<TypeMapNodeFactory> GetExternalTypeMapUniverse(TypeReference typeMapUniverse) => throw new NotImplementedException();
        internal DependencyNodeCore<TypeMapNodeFactory> GetPendingExternalTrimTargetNode(DependencyNodeCore<TypeMapNodeFactory> attributeKeptNode, DependencyNodeCore<TypeMapNodeFactory> trimTargetNode) => throw new NotImplementedException();
    }

    sealed class TypeMapDependencyGraph2
    {
        public static void Asdf() {}
    }

    internal abstract class TypeMapUniverseNode : DependencyNodeCore<TypeMapNodeFactory>
    {
        protected TypeDefinition _type;

        public TypeMapUniverseNode(TypeDefinition type)
        {
            _type = type;
        }

        public override bool InterestingForDynamicDependencyAnalysis => false;

        public override bool HasDynamicDependencies => false;

        public override bool HasConditionalStaticDependencies => false;

        public override bool StaticDependenciesAreComputed => true;

        public override IEnumerable<CombinedDependencyListEntry>? GetConditionalStaticDependencies(TypeMapNodeFactory context)
        {
            return null!;
        }

        public override IEnumerable<DependencyListEntry>? GetStaticDependencies(TypeMapNodeFactory context) => null!;
        public override IEnumerable<CombinedDependencyListEntry>? SearchDynamicDependencies(List<DependencyNodeCore<TypeMapNodeFactory>> markedNodes, int firstNode, TypeMapNodeFactory context) => null;
    }

    sealed class ProxyTypeMapUniverseNode : TypeMapUniverseNode
    {
        public ProxyTypeMapUniverseNode(TypeDefinition _type) : base(_type)
        {
        }

        protected override string GetName(TypeMapNodeFactory context) => $"ProxyTypeUniverse: {_type.GetDisplayName()}";
    }

    sealed class ExternalTypeMapUniverseNode : TypeMapUniverseNode
    {
        public ExternalTypeMapUniverseNode(TypeDefinition _type) : base(_type)
        {
        }

        protected override string GetName(TypeMapNodeFactory context) => $"ExternalTypeUniverse: {_type.GetDisplayName()}";
    }

